# FoodHub local environment (example)
#
# This app reads values via compile-time Dart defines (see lib/core/config.dart):
# - SUPABASE_URL
# - SUPABASE_ANON_KEY (or SUPABASE_PUBLISHABLE_KEY)
#
# Fill these in and copy this file to `.env` (which is git-ignored).
#
# Run (example):
#   flutter run -d chrome --dart-define=SUPABASE_URL=$SUPABASE_URL --dart-define=SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY
#
# If your Flutter version supports it, you can also try:
#   flutter run -d chrome --dart-define-from-file=.env

SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Alternative key name accepted by this app (leave empty if using ANON_KEY):
SUPABASE_PUBLISHABLE_KEY=

# Optional (used by some screens):
GOOGLE_MAPS_API_KEY=
